{
  "openapi": "3.0.0",
  "info": {
    "title": "belaf CLI API",
    "version": "1.1.0",
    "description": "API surface consumed by the belaf CLI (Rust). Wire format is snake_case. Source schemas live in apps/api/src/routes/cli/schemas.ts and are re-generated into Rust types via progenitor in the belaf repo. OpenAPI 3.0 (not 3.1) for progenitor compatibility."
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Better Auth bearer token (issued via OAuth Device Flow)."
      }
    },
    "schemas": {
      "UserInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "username": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "tier": {
            "type": "string"
          },
          "current": {
            "type": "integer"
          },
          "limit": {
            "type": "string"
          },
          "upgrade_url": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "CheckInstallationResponse": {
        "type": "object",
        "properties": {
          "installed": {
            "type": "boolean"
          },
          "installation_id": {
            "type": "integer"
          },
          "repository_id": {
            "type": "integer"
          },
          "install_url": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "installed"
        ]
      },
      "CommitAuthor": {
        "type": "object",
        "properties": {
          "login": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "login",
          "name"
        ]
      },
      "ApiCommit": {
        "type": "object",
        "properties": {
          "sha": {
            "type": "string"
          },
          "message": {
            "type": "string",
            "nullable": true
          },
          "author": {
            "$ref": "#/components/schemas/CommitAuthor"
          },
          "timestamp": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "sha"
        ]
      },
      "CommitsResponse": {
        "type": "object",
        "properties": {
          "commits": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiCommit"
            }
          },
          "has_more": {
            "type": "boolean"
          }
        },
        "required": [
          "commits",
          "has_more"
        ]
      },
      "ApiPullRequest": {
        "type": "object",
        "properties": {
          "number": {
            "type": "integer"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "merge_commit_sha": {
            "type": "string",
            "nullable": true
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "merged_at": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "number",
          "labels"
        ]
      },
      "PullRequestsResponse": {
        "type": "object",
        "properties": {
          "pull_requests": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ApiPullRequest"
            }
          },
          "has_more": {
            "type": "boolean"
          }
        },
        "required": [
          "pull_requests",
          "has_more"
        ]
      },
      "CreatePullRequestResponse": {
        "type": "object",
        "properties": {
          "number": {
            "type": "integer"
          },
          "html_url": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "number",
          "html_url"
        ]
      },
      "CreatePullRequestRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "head": {
            "type": "string"
          },
          "base": {
            "type": "string"
          },
          "body": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "head",
          "base"
        ]
      },
      "GitCredentialsResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "expires_at": {
            "type": "string"
          }
        },
        "required": [
          "token",
          "expires_at"
        ]
      },
      "ReportDriftResponse": {
        "type": "object",
        "properties": {
          "accepted": {
            "type": "boolean"
          }
        },
        "required": [
          "accepted"
        ]
      },
      "ReportDriftRequest": {
        "type": "object",
        "properties": {
          "uncovered_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "uncovered_paths"
        ]
      },
      "OidcExchangeResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string",
            "enum": [
              "Bearer"
            ]
          },
          "expires_at": {
            "type": "string"
          },
          "installation_id": {
            "type": "integer"
          },
          "repository_id": {
            "type": "integer"
          }
        },
        "required": [
          "access_token",
          "token_type",
          "expires_at",
          "installation_id",
          "repository_id"
        ]
      },
      "OidcExchangeRequest": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          }
        },
        "required": [
          "token"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/me": {
      "get": {
        "operationId": "getMe",
        "tags": [
          "CLI"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Get current authenticated CLI user",
        "responses": {
          "200": {
            "description": "User info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserInfo"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/check-installation": {
      "get": {
        "operationId": "checkInstallation",
        "tags": [
          "CLI"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Check whether the belaf GitHub App is installed on a repository",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1,
              "example": "owner/repo"
            },
            "required": true,
            "name": "repo",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Installation status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckInstallationResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repos/{owner}/{repo}/commits": {
      "get": {
        "operationId": "listCommits",
        "tags": [
          "CLI"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List commits for a repository (paginated)",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "owner",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "repo",
            "in": "path"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "ref",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "required": false,
            "name": "per_page",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "required": false,
            "name": "page",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Commits page",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommitsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repos/{owner}/{repo}/pulls": {
      "get": {
        "operationId": "listPulls",
        "tags": [
          "CLI"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List pull requests for a repository (paginated)",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "owner",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "repo",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "closed",
                "all"
              ]
            },
            "required": false,
            "name": "state",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "required": false,
            "name": "per_page",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "required": false,
            "name": "page",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Pull requests page",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PullRequestsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPull",
        "tags": [
          "CLI"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Create a pull request via the GitHub App",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "owner",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "repo",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePullRequestRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Pull request created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePullRequestResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Repository limit exceeded — upgrade required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "PR already exists or invalid branch",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repos/{owner}/{repo}/git/credentials": {
      "get": {
        "operationId": "getGitCredentials",
        "tags": [
          "CLI"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Mint a short-lived installation token scoped to contents:write",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "owner",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "repo",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Installation token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GitCredentialsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Repository limit exceeded — upgrade required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/repos/{owner}/{repo}/drift": {
      "post": {
        "operationId": "reportDrift",
        "tags": [
          "CLI"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Report the current drift state from `belaf prepare`. Empty array means the run found no drift.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "owner",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "repo",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportDriftRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Drift state recorded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportDriftResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/oidc/exchange": {
      "post": {
        "operationId": "exchangeOidcToken",
        "tags": [
          "CLI"
        ],
        "summary": "Exchange a GitHub Actions OIDC JWT for a short-lived belaf CI token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OidcExchangeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "CI token issued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OidcExchangeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Malformed request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid OIDC token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "belaf GitHub App not installed on this repository",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}
